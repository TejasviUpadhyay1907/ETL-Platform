# =============================================================================
# Enterprise ETL & Data Quality Platform v1.0.0 — Environment Configuration
# =============================================================================
#
# USAGE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in values marked with  ← REQUIRED
#   3. Generate secrets:  python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# NEVER commit your .env file to version control.
# This .env.example is safe to commit — it contains no real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION — Core settings
# ---------------------------------------------------------------------------
APP_NAME=ETL Platform
APP_VERSION=1.0.0

# Environment: development | staging | production
# development → verbose errors, hot-reload, SQL echo available
# production  → hides stack traces, enforces TLS, strict validation
APP_ENV=development

HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# SECURITY — ← REQUIRED: Generate fresh values for every deployment
# ---------------------------------------------------------------------------

# Application secret key — used for signing tokens and internal encryption
# Minimum 32 characters. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars   # ← REQUIRED

# JWT signing secret — DIFFERENT from SECRET_KEY
# Minimum 32 characters.
JWT_SECRET=change-this-jwt-secret-min-32-chars                   # ← REQUIRED

# JWT algorithm — HS256 (HMAC-SHA256) is default and recommended
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 1440 = 24 hours)
# For high-security environments, use 60 (1 hour)
JWT_EXPIRATION_MINUTES=1440

# Salt used when hashing API keys with SHA-256
# Minimum 16 characters.
API_KEY_SALT=change-this-salt-value-min-16-chars                 # ← REQUIRED

# ---------------------------------------------------------------------------
# DATABASE — PostgreSQL connection
# ---------------------------------------------------------------------------

# Full PostgreSQL connection URL
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://etl_user:etl_password@localhost:5432/etl_platform  # ← REQUIRED

# Connection pool configuration
DB_POOL_SIZE=10          # Number of persistent connections in pool
DB_MAX_OVERFLOW=20       # Extra connections allowed beyond pool_size
DB_POOL_TIMEOUT=30       # Seconds to wait for a connection from pool
DB_POOL_RECYCLE=3600     # Recycle connections older than this (seconds)

# Set to True to log every SQL query (development only — verbose!)
DB_ECHO=False

# ---------------------------------------------------------------------------
# DOCKER COMPOSE — used by docker-compose files
# These are separate from DATABASE_URL and used by the db service
# ---------------------------------------------------------------------------
DB_USER=etl_user
DB_PASSWORD=etl_password     # ← REQUIRED in production
DB_NAME=etl_platform

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE_PATH=logs/app.log

# Log file rotation settings
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10

# Use JSON format (True for production/log-aggregation, False for human-readable dev)
LOG_JSON_FORMAT=False

# ---------------------------------------------------------------------------
# FILE STORAGE
# ---------------------------------------------------------------------------

# Directories for file processing (relative to project root)
UPLOAD_DIRECTORY=data/raw
REPORT_DIRECTORY=data/reports
ARCHIVE_DIRECTORY=data/archive

# Maximum uploaded file size in megabytes
MAX_UPLOAD_SIZE_MB=500

# Comma-separated list of allowed file extensions (no dots)
ALLOWED_FILE_TYPES=csv,xlsx,xls

# ---------------------------------------------------------------------------
# PIPELINE EXECUTION
# ---------------------------------------------------------------------------

# Number of rows to process per chunk (controls memory usage)
# Lower this for memory-constrained environments
PIPELINE_CHUNK_SIZE=10000

# Maximum number of concurrent pipeline runs
PIPELINE_MAX_CONCURRENT_RUNS=5

# Timeout for a single pipeline stage in seconds (default: 1 hour)
PIPELINE_STAGE_TIMEOUT_SECONDS=3600

# Enable/disable the APScheduler background scheduler
# Set False in tests and CI to avoid scheduler startup
PIPELINE_ENABLE_SCHEDULER=False

# ---------------------------------------------------------------------------
# API RATE LIMITING
# ---------------------------------------------------------------------------

# Master on/off switch for rate limiting
RATE_LIMIT_ENABLED=True

# Requests allowed per minute per user (or IP for unauthenticated)
RATE_LIMIT_PER_MINUTE=60

# Requests allowed per hour per user
RATE_LIMIT_PER_HOUR=1000

# ---------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# ---------------------------------------------------------------------------

CORS_ENABLED=True

# Comma-separated list of allowed origins
# Production: set to your actual frontend domain(s)
# Development: http://localhost:3000,http://localhost:8000,http://localhost:8501
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# ---------------------------------------------------------------------------
# DATA QUALITY THRESHOLDS
# ---------------------------------------------------------------------------

# Quality score below this value triggers a WARNING (0-100)
QUALITY_SCORE_WARNING_THRESHOLD=80

# Quality score below this value causes pipeline FAILURE (0-100)
QUALITY_SCORE_FAILURE_THRESHOLD=50

# ---------------------------------------------------------------------------
# DASHBOARD (Streamlit)
# ---------------------------------------------------------------------------

# URL of the FastAPI backend (used by the dashboard's API client)
# When running both locally: http://localhost:8000
# When using Docker Compose: http://api:8000
DASHBOARD_API_URL=http://localhost:8000

# Timeout in seconds for dashboard → API HTTP requests
DASHBOARD_API_TIMEOUT=15

# ---------------------------------------------------------------------------
# MONITORING — Prometheus / Grafana (docker-compose.monitoring.yml)
# ---------------------------------------------------------------------------

# Port for Prometheus web UI (default: 9090)
PROMETHEUS_PORT=9090

# Port for Grafana web UI (default: 3000)
GRAFANA_PORT=3000

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme   # ← REQUIRED in production

# ---------------------------------------------------------------------------
# DOCKER COMPOSE — Production port overrides
# ---------------------------------------------------------------------------

# HTTP and HTTPS ports exposed by Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Docker image version tag
VERSION=1.0.0

# ---------------------------------------------------------------------------
# DEVELOPMENT UTILITIES (optional)
# ---------------------------------------------------------------------------

# Seed script random seed (ensures reproducible dev data)
# SEED_RANDOM_SEED=42

# Number of worker processes for uvicorn (production)
# Defaults to 4 in production, 1 in development
# UVICORN_WORKERS=4
