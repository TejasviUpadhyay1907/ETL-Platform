{
  "id": null,
  "uid": "etl-pipeline-execution",
  "title": "ETL Platform — Pipeline Execution",
  "tags": ["etl", "pipeline"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Pipeline Runs",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "sum(etl_pipeline_runs_total)", "legendFormat": "Total"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Successful Runs",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "sum(etl_pipeline_runs_total{status=\"succeeded\"})", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed Runs",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"expr": "sum(etl_pipeline_runs_total{status=\"failed\"})", "legendFormat": ""}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Pipelines",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"expr": "etl_pipeline_active_runs", "legendFormat": ""}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline Run Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum(rate(etl_pipeline_runs_total{status=\"succeeded\"}[5m])) * 300", "legendFormat": "Success (5m)"},
        {"expr": "sum(rate(etl_pipeline_runs_total{status=\"failed\"}[5m])) * 300", "legendFormat": "Failed (5m)"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pipeline Duration P50 / P95 by Dataset",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(etl_pipeline_duration_seconds_bucket[5m])) by (le, dataset_type))", "legendFormat": "p50 {{dataset_type}}"},
        {"expr": "histogram_quantile(0.95, sum(rate(etl_pipeline_duration_seconds_bucket[5m])) by (le, dataset_type))", "legendFormat": "p95 {{dataset_type}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Records Processed",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum(rate(etl_pipeline_records_processed_total[5m])) by (stage) * 60", "legendFormat": "{{stage}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ],
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {}
}
